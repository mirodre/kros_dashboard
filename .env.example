AUTH_SECRET=change-me-use-openssl-rand-hex-32
# DASHBOARD_PASSWORD: heslo pre /login (min. 8 znakov)
DASHBOARD_PASSWORD=change-me-strong-password

# === Voliteľné KROS API ===
KROS_API_BASE_URL=https://api-economy.kros.sk
NEXT_PUBLIC_KROS_CONSENT_BASE_URL=https://firma.kros.sk/integration-consent
